# ============================================================
# datos-de-azar — Variables de entorno (ejemplo)
# ============================================================
# Copiar este archivo a `.env` (que está en .gitignore) y ajustar.
# El frontend Next.js lee de `.env.local`; el scraper Python lee de `.env`.
# ============================================================

# ---------- Base de datos ----------
# Prisma + SQLAlchemy: una sola URL fuente de la verdad.
# Local (docker-compose):
DATABASE_URL="mysql://dev:devpass@127.0.0.1:3306/datos_azar"

# Hostinger (producción) — ejemplo, reemplazar credenciales reales:
# DATABASE_URL="mysql://USUARIO:PASSWORD@HOST:3306/datos_azar"

# Para el scraper Python, también puede usar piezas separadas:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=dev
# DB_PASS=devpass
# DB_NAME=datos_azar

# ---------- Frontend Next.js ----------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------- Scraper Python ----------
SCRAPER_DELAY_SECONDS=1.5
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
LOG_LEVEL=INFO
# DRY_RUN=true   # útil para depurar sin escribir a la BD
